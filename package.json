{
  "name": "forgefx-midi",
  "version": "0.3.28",
  "description": "Fractal Audio device codec + catalogs for ForgeFX (gen1, Axe-Fx II, gen3 FM3/FM9/Axe-Fx III/VP4, AM4)",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "default": "./dist/shared/index.js"
    },
    "./cache": {
      "types": "./dist/cache/index.d.ts",
      "default": "./dist/cache/index.js"
    },
    "./am4": {
      "types": "./dist/am4/index.d.ts",
      "default": "./dist/am4/index.js"
    },
    "./gen1": {
      "types": "./dist/gen1/index.d.ts",
      "default": "./dist/gen1/index.js"
    },
    "./gen2/axe-fx-ii": {
      "types": "./dist/gen2/axe-fx-ii/index.d.ts",
      "default": "./dist/gen2/axe-fx-ii/index.js"
    },
    "./gen3/axe-fx-iii": {
      "types": "./dist/gen3/axe-fx-iii/index.d.ts",
      "default": "./dist/gen3/axe-fx-iii/index.js"
    },
    "./gen3/fm3": {
      "types": "./dist/gen3/fm3/index.d.ts",
      "default": "./dist/gen3/fm3/index.js"
    },
    "./gen3/fm9": {
      "types": "./dist/gen3/fm9/index.d.ts",
      "default": "./dist/gen3/fm9/index.js"
    },
    "./gen3/vp4": {
      "types": "./dist/gen3/vp4/index.d.ts",
      "default": "./dist/gen3/vp4/index.js"
    },
    "./convert": {
      "types": "./dist/convert/index.d.ts",
      "default": "./dist/convert/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./core/midi": {
      "types": "./dist/core/midi/index.d.ts",
      "default": "./dist/core/midi/index.js"
    },
    "./devices/gen1": {
      "types": "./dist/devices/gen1/index.d.ts",
      "default": "./dist/devices/gen1/index.js"
    },
    "./devices/gen2": {
      "types": "./dist/devices/gen2/index.d.ts",
      "default": "./dist/devices/gen2/index.js"
    },
    "./devices/gen3": {
      "types": "./dist/devices/gen3/index.d.ts",
      "default": "./dist/devices/gen3/index.js"
    },
    "./devices/am4": {
      "types": "./dist/devices/am4/index.d.ts",
      "default": "./dist/devices/am4/index.js"
    },
    "./catalog/*.json": "./catalog/*.json"
  },
  "files": [
    "dist",
    "catalog",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "scripts": {
    "build": "tsx scripts/gen-version.ts && tsc -p tsconfig.json && tsx scripts/copy-build-assets.ts",
    "test": "tsx test/run-all.ts && tsx scripts/check-browser-safe.ts && tsx scripts/export-catalog.ts --check && tsx scripts/cache-check.ts",
    "check:browser": "tsx scripts/check-browser-safe.ts",
    "prepack": "npm run build",
    "catalog:export": "tsx scripts/export-catalog.ts",
    "catalog:check": "tsx scripts/export-catalog.ts --check",
    "cache:check": "tsx scripts/cache-check.ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.25.12",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.16.0"
  }
}
